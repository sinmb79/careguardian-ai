{
  "expo": {
    "name": "CareGuardian AI",
    "slug": "careguardian-ai-mobile",
    "version": "1.0.1",
    "orientation": "default",
    "icon": "./assets/icon.png",
    "userInterfaceStyle": "light",
    "newArchEnabled": true,
    "splash": {
      "image": "./assets/splash-icon.png",
      "resizeMode": "contain",
      "backgroundColor": "#f4ecde"
    },
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "com.sinmb.careguardianai",
      "infoPlist": {
        "NSFaceIDUsageDescription": "저장된 돌봄 정보를 보호하기 위해 기기 인증을 사용합니다."
      }
    },
    "android": {
      "package": "com.sinmb.careguardianai",
      "adaptiveIcon": {
        "foregroundImage": "./assets/adaptive-icon.png",
        "backgroundColor": "#1F2A2A"
      },
      "edgeToEdgeEnabled": true,
      "predictiveBackGestureEnabled": false,
      "versionCode": 6,
      "allowBackup": false,
      "permissions": [
        "android.permission.POST_NOTIFICATIONS"
      ],
      "blockedPermissions": [
        "android.permission.READ_EXTERNAL_STORAGE",
        "android.permission.READ_MEDIA_IMAGES",
        "android.permission.WRITE_EXTERNAL_STORAGE",
        "android.permission.SYSTEM_ALERT_WINDOW",
        "com.google.android.finsky.permission.BIND_GET_INSTALL_REFERRER_SERVICE"
      ]
    },
    "web": {
      "favicon": "./assets/favicon.png"
    },
    "plugins": [
      [
        "expo-secure-store",
        {
          "configureAndroidBackup": true,
          "faceIDPermission": "저장된 돌봄 정보를 보호하기 위해 기기 인증을 사용합니다."
        }
      ],
      [
        "expo-sqlite",
        {
          "useSQLCipher": true
        }
      ],
      [
        "expo-local-authentication",
        {
          "faceIDPermission": "저장된 돌봄 정보를 보호하기 위해 기기 인증을 사용합니다."
        }
      ],
      "expo-notifications",
      "expo-font",
      "./plugins/with-local-only-notifications"
    ],
    "extra": {
      "eas": {
        "projectId": "15b9e293-b631-4b77-8cfc-9937cd604dd4"
      }
    },
    "owner": "sinmb79"
  }
}
