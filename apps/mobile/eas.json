{
  "cli": {
    "version": ">= 16.18.0",
    "appVersionSource": "local"
  },
  "build": {
    "development": {
      "distribution": "internal",
      "env": {
        "EXPO_NO_METRO_WORKSPACE_ROOT": "1"
      }
    },
    "preview": {
      "distribution": "internal",
      "env": {
        "EXPO_NO_METRO_WORKSPACE_ROOT": "1",
        "NODE_ENV": "production"
      }
    },
    "production": {
      "autoIncrement": true,
      "android": {
        "buildType": "app-bundle"
      },
      "env": {
        "EXPO_NO_METRO_WORKSPACE_ROOT": "1",
        "NODE_ENV": "production"
      }
    }
  },
  "submit": {
    "production": {}
  }
}
