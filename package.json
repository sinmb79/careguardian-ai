{
  "name": "careguardian-ai",
  "private": true,
  "version": "0.1.0",
  "packageManager": "npm@11.9.0",
  "engines": {
    "node": ">=20.19.4 <25"
  },
  "overrides": {
    "serialize-javascript": "7.0.7"
  },
  "type": "module",
  "workspaces": [
    "apps/*",
    "packages/*"
  ],
  "scripts": {
    "dev": "vite",
    "build": "tsc --noEmit -p tsconfig.app.json && tsc --noEmit -p tsconfig.node.json && vite build",
    "mobile:start": "npm --workspace apps/mobile run start",
    "mobile:android": "npm --workspace apps/mobile run android",
    "mobile:android:go": "npm --workspace apps/mobile run android:go",
    "mobile:android:dev": "npm --workspace apps/mobile run android:dev",
    "mobile:ios": "npm --workspace apps/mobile run ios",
    "mobile:web": "npm --workspace apps/mobile run web",
    "mobile:typecheck": "tsc --noEmit -p apps/mobile/tsconfig.json",
    "mobile:doctor": "npm --workspace apps/mobile run doctor",
    "preview": "vite preview",
    "test": "vitest",
    "verify": "npm test -- --run && npm run build && npm run mobile:typecheck && npm run mobile:doctor"
  },
  "dependencies": {
    "@careguardian/care-core": "file:packages/care-core",
    "react": "19.1.0",
    "react-dom": "19.1.0"
  },
  "devDependencies": {
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.2",
    "@testing-library/user-event": "^14.6.1",
    "@types/node": "^24.6.0",
    "@types/react": "~19.1.0",
    "@types/react-dom": "~19.1.0",
    "@vitejs/plugin-react": "^5.2.0",
    "autoprefixer": "^10.4.27",
    "jsdom": "^29.0.2",
    "postcss": "^8.5.9",
    "puppeteer": "^24.40.0",
    "sharp": "^0.34.5",
    "tailwindcss": "^3.4.17",
    "typescript": "~5.9.2",
    "vite": "^7.3.6",
    "vite-plugin-pwa": "^1.2.0",
    "vitest": "^4.1.3"
  }
}
